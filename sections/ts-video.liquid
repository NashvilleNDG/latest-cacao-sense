{% liquid
  assign video = section.settings.video
  assign vurl = section.settings.video_url
  assign autoplay = section.settings.autoplay
  assign controls = section.settings.show_controls
  assign loop = section.settings.loop
%}

<section class="ts-video-sec">
  <div class="ts-page-width">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subtext != blank %}
      <div class="ts-video-sec__head">
        {% if section.settings.eyebrow != blank %}<p class="ts-products__kicker">{{ section.settings.eyebrow }}</p>{% endif %}
        {% if section.settings.heading != blank %}<h2 class="ts-products__title">{{ section.settings.heading }}</h2>{% endif %}
        {% if section.settings.subtext != blank %}<p class="ts-video-sec__sub">{{ section.settings.subtext }}</p>{% endif %}
      </div>
    {% endif %}

    <div class="ts-video-sec__frame">
      {% if video != blank %}
        {{ video | video_tag: image_size: '1600x', controls: controls, autoplay: autoplay, loop: loop, muted: autoplay, playsinline: true, preload: 'metadata' }}
      {% elsif vurl != blank %}
        {%- liquid
          assign yt = 'rel=0&modestbranding=1&playsinline=1'
          assign vm = 'title=0&byline=0&portrait=0&dnt=1'
          if autoplay
            assign yt = yt | append: '&autoplay=1&mute=1'
            assign vm = vm | append: '&autoplay=1&muted=1'
          endif
          if loop
            assign vm = vm | append: '&loop=1'
            if vurl.type == 'youtube'
              assign yt = yt | append: '&loop=1&playlist=' | append: vurl.id
            endif
          endif
        -%}
        {% if vurl.type == 'youtube' %}
          <iframe src="https://www.youtube.com/embed/{{ vurl.id }}?{{ yt }}" title="{{ section.settings.heading | default: 'Video' | escape }}" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen loading="lazy"></iframe>
        {% elsif vurl.type == 'vimeo' %}
          <iframe src="https://player.vimeo.com/video/{{ vurl.id }}?{{ vm }}" title="{{ section.settings.heading | default: 'Video' | escape }}" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy"></iframe>
        {% endif %}
      {% else %}
        <div class="ts-video-sec__placeholder">
          <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"></polygon></svg>
          <p>{{ section.settings.placeholder_text }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video",
  "tag": "section",
  "class": "section-ts-video",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Watch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From Our Farm to Your Cup" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "A short look at how our single-origin cacao is grown, harvested, and crafted." },
    { "type": "header", "content": "Video source" },
    { "type": "video", "id": "video", "label": "Video (uploaded to Shopify)", "info": "Recommended for large files — Shopify hosts and streams it. Upload your ~45s clip here." },
    { "type": "video_url", "id": "video_url", "label": "…or external video URL", "accept": ["youtube", "vimeo"], "info": "YouTube or Vimeo link. Used only if no uploaded video is set." },
    { "type": "header", "content": "Playback" },
    { "type": "checkbox", "id": "show_controls", "label": "Show player controls", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay (auto-mutes)", "default": false },
    { "type": "checkbox", "id": "loop", "label": "Loop", "default": false },
    { "type": "text", "id": "placeholder_text", "label": "Placeholder text (shown before a video is added)", "default": "Add your video in the theme editor" }
  ],
  "presets": [{ "name": "Video" }]
}
{% endschema %}
