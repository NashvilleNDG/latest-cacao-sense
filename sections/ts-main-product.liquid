{% comment %}
  Product detail page — theme-managed catalog (browse-only, no price/cart).

  Content comes from snippets/ts-product-info.liquid, the same source the shop
  grid uses, keyed by product.handle. Products not in that list fall back to
  their Shopify data (still without price).
{% endcomment %}

{%- capture handles_csv -%}{%- render 'ts-product-handles' -%}{%- endcapture -%}
{%- assign known = handles_csv | strip | split: ',' -%}

{% liquid
  assign url_contact = '/pages/contact'
  if pages['contact'] != blank
    assign url_contact = pages['contact'].url
  endif
%}

<section class="ts-pdp-section ts-page-width">
  {% if known contains product.handle %}
    {% render 'ts-product-info', handle: product.handle, mode: 'detail' %}
  {% else %}
    <div class="ts-pdp">
      <div class="ts-pdp__gallery">
        <div class="ts-pdp__main">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title | escape }}">
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>
      <div class="ts-pdp__info">
        <p class="ts-pdp__eyebrow">{{ section.settings.fallback_origin }}</p>
        <h1 class="ts-pdp__title">{{ product.title }}</h1>
        <div class="ts-pdp__lead rte">{{ product.description }}</div>
        <a class="ts-btn ts-btn--primary ts-pdp__cta" href="{{ url_contact }}">
          Enquire About This Product
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
        </a>
        <a class="ts-pdp__back" href="{{ routes.all_products_collection_url }}">← Back to all products</a>
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-ts-product",
  "settings": [
    {
      "type": "paragraph",
      "content": "Catalog products render from snippets/ts-product-info.liquid. Settings below only affect products not in that list."
    },
    {
      "type": "text",
      "id": "fallback_origin",
      "label": "Fallback origin text",
      "default": "Guatemala"
    }
  ]
}
{% endschema %}
