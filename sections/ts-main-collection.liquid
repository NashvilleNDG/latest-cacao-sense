{% comment %}
  Shop page — theme-managed catalog grid.

  Tiles show image + name only; full details live on the product page
  (/products/<handle>), rendered by snippets/ts-product-info.liquid.

  To add a product: add its handle to snippets/ts-product-handles.liquid, add a
  `when` branch in snippets/ts-product-info.liquid, and drop <handle>.webp +
  <handle>-pack.webp in assets/.
{% endcomment %}

{%- capture handles_csv -%}{%- render 'ts-product-handles' -%}{%- endcapture -%}
{%- assign handles = handles_csv | strip | split: ',' -%}

{%- liquid
  assign hero_img = section.settings.hero_image
  assign hero_fallback = 'shop-hero.webp' | asset_url
-%}

<div class="ts-os-page">
  <section class="ts-os-hero">
    <div class="ts-os-hero__bg">
      {% if hero_img != blank %}
        <img src="{{ hero_img | image_url: width: 2400 }}" alt="{{ section.settings.hero_image_alt | escape }}" width="{{ hero_img.width }}" height="{{ hero_img.height }}" loading="eager" fetchpriority="high">
      {% else %}
        <img src="{{ hero_fallback }}" alt="{{ section.settings.hero_image_alt | escape }}" width="1536" height="1024" loading="eager" fetchpriority="high">
      {% endif %}
      <div class="ts-os-hero__shade"></div>
    </div>
    <div class="ts-os-hero__content ts-page-width">
      {% if section.settings.kicker != blank %}
        <p class="ts-os-hero__eyebrow">{{ section.settings.kicker }}</p>
      {% endif %}
      <h1 class="ts-os-hero__title">{{ section.settings.title }}</h1>
      {% if section.settings.intro != blank %}
        <p class="ts-os-hero__lead">{{ section.settings.intro }}</p>
      {% endif %}
    </div>
  </section>

  <section class="ts-catalog ts-page-width">
    <div class="ts-catalog__grid">
      {% for handle in handles %}
        {% render 'ts-product-info', handle: handle, mode: 'card' %}
      {% endfor %}
    </div>

    {% if section.settings.note != blank %}
      <p class="ts-catalog__note">{{ section.settings.note }}</p>
    {% endif %}
  </section>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-ts-os-page",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero image", "info": "Falls back to asset shop-hero.webp if empty." },
    { "type": "text", "id": "hero_image_alt", "label": "Hero image alt", "default": "The full Cacao Senses product range" },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Products"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Single-origin cacao, grown on our own farms in the highlands of Guatemala and crafted in small batches."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Footer note",
      "default": "Every product is 100% pure cacao — no additives, no fillers, no sugar. Get in touch for availability and bulk enquiries."
    }
  ]
}
{% endschema %}
