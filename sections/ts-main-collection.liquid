<section class="ts-collection-page ts-page-width" style="padding:2.5rem 1.5rem 4rem;">
  <header style="margin-bottom:3rem;">
    <p class="ts-products__kicker">{{ section.settings.kicker }}</p>
    <h1 class="ts-products__title">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <div class="rte" style="max-width:40rem;color:var(--ts-muted-fg);margin-top:1rem;">
        {{ collection.description }}
      </div>
    {% endif %}
  </header>
  {% paginate collection.products by section.settings.products_per_page %}
    <div class="ts-products__grid">
      {% for product in collection.products %}
        {% render 'ts-product-card', product: product %}
      {% endfor %}
    </div>
    {% if paginate.pages > 1 %}
      <nav class="ts-pagination" style="margin-top:3rem;display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        {% if paginate.previous %}
          <a href="{{ paginate.previous.url }}" class="ts-btn-outline">{{ 'general.pagination.previous' | t }}</a>
        {% endif %}
        {% if paginate.next %}
          <a href="{{ paginate.next.url }}" class="ts-btn-outline">{{ 'general.pagination.next' | t }}</a>
        {% endif %}
      </nav>
    {% endif %}
  {% endpaginate %}
</section>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-ts-collection",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Shop"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 24,
      "step": 4,
      "label": "Products per page",
      "default": 12
    }
  ]
}
{% endschema %}
