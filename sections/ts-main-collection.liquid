{% comment %}
  Shop page — theme-managed catalog.

  Products are defined here in Liquid (not Shopify products, and not section
  blocks) so they can be edited straight from GitHub. Section blocks live in
  templates/collection.json, which is why they are not used here.

  To add a product:
    1. Drop its image in assets/ (e.g. assets/cacao-nibs.webp)
    2. Copy one `render 'ts-catalog-card'` call below and edit the values.
{% endcomment %}

{% liquid
  assign contact_url = '/pages/contact'
%}

<section class="ts-catalog ts-page-width">
  <header class="ts-catalog__head">
    <p class="ts-products__kicker">{{ section.settings.kicker }}</p>
    <h1 class="ts-products__title">{{ section.settings.title }}</h1>
    {% if section.settings.intro != blank %}
      <p class="ts-catalog__intro">{{ section.settings.intro }}</p>
    {% endif %}
  </header>

  <div class="ts-catalog__grid">
    {% render 'ts-catalog-card',
      name: 'Cacao Powder',
      image: 'cacao-powder.webp',
      origin: 'Single Origin · Product of Guatemala',
      tagline: "From Guatemala's volcanic region. Mineral-rich volcanic soil, rainforest climate and careful cultivation result in cacao that is aromatic, nutrient-dense and flavor-forward.",
      bullets: '100% rich chocolate taste;Full-bodied aroma;Rich in antioxidants & theobromine;High in flavonoids;Natural energy and magnesium',
      uses: 'Chocolatiering;Baking;Skin & Body Care',
      net_wt: '8oz (227g)',
      servings: '38 servings (1 tsp / 6g)',
      ingredients: '100% Pure Cacao (Theobroma cacao)',
      badge: 'Zero Sugar',
      cta_label: 'Enquire',
      cta_url: contact_url
    %}
  </div>

  {% if section.settings.note != blank %}
    <p class="ts-catalog__note">{{ section.settings.note }}</p>
  {% endif %}
</section>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-ts-collection",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Products"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Single-origin cacao, grown on our own farms in the highlands of Guatemala and crafted in small batches."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Footer note",
      "default": "More products coming soon. Get in touch for availability and bulk enquiries."
    }
  ]
}
{% endschema %}
