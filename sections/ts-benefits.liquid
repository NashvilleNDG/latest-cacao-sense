<section class="ts-benefits" id="benefits">
  <div class="ts-benefits__glow" aria-hidden="true"></div>
  <div class="ts-page-width">
    <div class="ts-benefits__head">
      <p class="ts-products__kicker">{{ section.settings.kicker }}</p>
      <h2 class="ts-products__title">
        {{ section.settings.title_plain }} <em class="italic" style="color: var(--ts-accent);">{{ section.settings.title_accent }}</em>
      </h2>
      {% if section.settings.intro != blank %}
        <p class="ts-benefits__intro">{{ section.settings.intro }}</p>
      {% endif %}
    </div>
    <div class="ts-benefits__grid">
      {% for block in section.blocks %}
        {% if block.type == 'benefit' %}
          <div class="ts-benefit-card" {{ block.shopify_attributes }}>
            <div class="ts-benefit-card__icon ts-benefit-card__icon--{{ block.settings.tone }}">
              {% case block.settings.icon %}
                {% when 'zap' %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
                {% when 'heart' %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                {% when 'shield' %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                {% when 'leaf' %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg>
                {% when 'droplets' %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22a7 7 0 0 0 7-7c0-5-7-13-7-13S5 10 5 15a7 7 0 0 0 7 7z"></path></svg>
                {% else %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="5"></circle><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path></svg>
              {% endcase %}
            </div>
            <h3 class="ts-benefit-card__title">{{ block.settings.title }}</h3>
            <p class="ts-benefit-card__desc">{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits grid",
  "tag": "section",
  "class": "section-ts-benefits",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Why Cacao?"
    },
    {
      "type": "text",
      "id": "title_plain",
      "label": "Title (plain)",
      "default": "The Superfood "
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Title (accent)",
      "default": "Benefits"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Cacao is one of the most nutrient-dense foods on the planet. Here's why thousands make it part of their daily ritual."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "zap", "label": "Energy" },
            { "value": "heart", "label": "Heart" },
            { "value": "shield", "label": "Shield" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "droplets", "label": "Droplets" },
            { "value": "sun", "label": "Sun" }
          ],
          "default": "zap"
        },
        {
          "type": "select",
          "id": "tone",
          "label": "Icon color",
          "options": [
            { "value": "amber", "label": "Amber" },
            { "value": "rose", "label": "Rose" },
            { "value": "purple", "label": "Purple" },
            { "value": "green", "label": "Green" },
            { "value": "blue", "label": "Blue" },
            { "value": "yellow", "label": "Yellow" }
          ],
          "default": "amber"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Description text."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits grid",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "zap", "tone": "amber", "title": "Natural Energy Boost", "text": "Cacao contains theobromine, a gentle stimulant that provides sustained energy without the crash of caffeine." } },
        { "type": "benefit", "settings": { "icon": "heart", "tone": "rose", "title": "Heart Health", "text": "Rich in flavonoids that support cardiovascular health, improve circulation and lower blood pressure naturally." } },
        { "type": "benefit", "settings": { "icon": "shield", "tone": "purple", "title": "Antioxidant Powerhouse", "text": "One of the highest antioxidant scores of any food on earth — 40× more than blueberries." } },
        { "type": "benefit", "settings": { "icon": "leaf", "tone": "green", "title": "100% Pure & Natural", "text": "No additives, no preservatives, no fillers. Just pure cacao as nature intended." } },
        { "type": "benefit", "settings": { "icon": "droplets", "tone": "blue", "title": "Magnesium Rich", "text": "Exceptional source of magnesium supporting muscle function, relaxation, and restful sleep." } },
        { "type": "benefit", "settings": { "icon": "sun", "tone": "yellow", "title": "Mood Enhancement", "text": "Triggers release of serotonin and endorphins — nature's own mood-lifting superfood." } }
      ]
    }
  ]
}
{% endschema %}

