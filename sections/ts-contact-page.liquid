{% liquid
  assign hero_img = section.settings.hero_image
  assign hero_fallback = 'Contact-Hero.webp' | asset_url
%}

<div class="ts-contact-page">
  <section class="ts-contact-hero">
    <div class="ts-contact-hero__bg">
      {% if hero_img != blank %}
        <img src="{{ hero_img | image_url: width: 2000 }}" alt="" width="{{ hero_img.width }}" height="{{ hero_img.height }}" loading="eager">
      {% else %}
        <img src="{{ hero_fallback }}" alt="" width="1600" height="900" loading="eager">
      {% endif %}
      <div class="ts-contact-hero__shade"></div>
    </div>
    <div class="ts-contact-hero__content ts-page-width">
      <p class="ts-contact-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
      <h1 class="ts-contact-hero__title">{{ section.settings.hero_title }}</h1>
      <p class="ts-contact-hero__lead">{{ section.settings.hero_lead }}</p>
    </div>
  </section>

  <section class="ts-contact-body ts-page-width">
    <div class="ts-contact-grid">
      <div class="ts-contact-form-wrap">
        <h2 class="ts-contact-form__title">{{ section.settings.form_title }}</h2>
        {% if section.settings.form_subtitle != blank %}
          <p class="ts-contact-form__sub">{{ section.settings.form_subtitle }}</p>
        {% endif %}

        {% if form.posted_successfully? %}
          <p class="ts-contact-form__success">{{ 'sections.contact.success' | t }}</p>
        {% endif %}

        {% form 'contact' %}
          {{ form.errors | default_errors }}
          <div class="ts-contact-form">

          <div class="ts-contact-form__row">
            <label class="visually-hidden" for="ContactFormName">{{ 'sections.contact.name' | t }}</label>
            <input
              id="ContactFormName"
              type="text"
              name="contact[name]"
              class="ts-contact-form__input"
              placeholder="{{ 'sections.contact.name' | t }}"
              autocomplete="name"
            >
          </div>
          <div class="ts-contact-form__row">
            <label class="visually-hidden" for="ContactFormEmail">{{ 'sections.contact.email' | t }}</label>
            <input
              id="ContactFormEmail"
              type="email"
              name="contact[email]"
              class="ts-contact-form__input"
              placeholder="{{ 'sections.contact.email' | t }}"
              autocomplete="email"
              required
            >
          </div>
          <div class="ts-contact-form__row">
            <label class="visually-hidden" for="ContactFormPhone">{{ 'sections.contact.phone' | t }}</label>
            <input
              id="ContactFormPhone"
              type="tel"
              name="contact[phone]"
              class="ts-contact-form__input"
              placeholder="{{ 'sections.contact.phone' | t }}"
              autocomplete="tel"
            >
          </div>
          <div class="ts-contact-form__row">
            <label class="visually-hidden" for="ContactFormMessage">{{ 'sections.contact.message' | t }}</label>
            <textarea
              id="ContactFormMessage"
              name="contact[body]"
              class="ts-contact-form__textarea"
              rows="6"
              placeholder="{{ 'sections.contact.message' | t }}"
              required
            ></textarea>
          </div>
          <button type="submit" class="ts-btn ts-btn--primary ts-contact-form__submit">
            {{ 'sections.contact.send' | t }}
          </button>
          </div>
        {% endform %}
      </div>

      <div class="ts-contact-cards">
        {% for block in section.blocks %}
          {% if block.type == 'info' %}
            <div class="ts-contact-card ts-contact-card--{{ block.settings.style }}" {{ block.shopify_attributes }}>
              <div class="ts-contact-card__icon" aria-hidden="true">
                {% case block.settings.style %}
                  {% when 'email' %}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  {% when 'phone' %}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                  {% when 'map' %}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  {% else %}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                {% endcase %}
              </div>
              <p class="ts-contact-card__label">{{ block.settings.label }}</p>
              <p class="ts-contact-card__value">{{ block.settings.value }}</p>
              {% if block.settings.sub != blank %}
                <p class="ts-contact-card__sub">{{ block.settings.sub }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ts-contact-faq" id="faq">
      <h2 class="ts-contact-faq__title">{{ section.settings.faq_title }}</h2>
      <div class="ts-contact-faq__list">
        {% for block in section.blocks %}
          {% if block.type == 'faq' %}
            <details class="ts-contact-faq__item" {{ block.shopify_attributes }}>
              <summary class="ts-contact-faq__q">{{ block.settings.question }}</summary>
              <div class="ts-contact-faq__a rte">{{ block.settings.answer }}</div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Contact page",
  "tag": "section",
  "class": "section-ts-contact-page",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "We'd Love to Hear From You" },
    { "type": "text", "id": "hero_title", "label": "Hero title", "default": "Contact" },
    { "type": "textarea", "id": "hero_lead", "label": "Hero subtitle", "default": "Questions about cacao, shipping, or wholesale? We're here to help." },
    { "type": "text", "id": "form_title", "label": "Form title", "default": "Send a message" },
    { "type": "textarea", "id": "form_subtitle", "label": "Form subtitle", "default": "Fill out the form and our team will respond within 24 hours." },
    { "type": "text", "id": "faq_title", "label": "FAQ heading", "default": "Frequently Asked Questions" }
  ],
  "blocks": [
    {
      "type": "info",
      "name": "Contact card",
      "settings": [
        {
          "type": "select",
          "id": "style",
          "label": "Type",
          "options": [
            { "value": "email", "label": "Email" },
            { "value": "phone", "label": "Phone" },
            { "value": "map", "label": "Location" },
            { "value": "clock", "label": "Hours" }
          ],
          "default": "email"
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Email Us" },
        { "type": "text", "id": "value", "label": "Value", "default": "hello@cacaosense.com" },
        { "type": "text", "id": "sub", "label": "Subline", "default": "We reply within 24 hours" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Question?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Answer text.</p>" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Contact page",
      "blocks": [
        { "type": "info", "settings": { "style": "email", "label": "Email Us", "value": "hello@cacaosense.com", "sub": "We reply within 24 hours" } },
        { "type": "info", "settings": { "style": "phone", "label": "Call Us", "value": "+1 (800) 123-4567", "sub": "Mon–Fri, 9am–6pm EST" } },
        { "type": "info", "settings": { "style": "map", "label": "Our Warehouse", "value": "128 Cacao Lane, New York, NY 10001", "sub": "United States" } },
        { "type": "info", "settings": { "style": "clock", "label": "Business Hours", "value": "Mon–Fri: 9am – 6pm", "sub": "Sat: 10am – 3pm EST" } },
        { "type": "faq", "settings": { "question": "Do you ship internationally?", "answer": "<p>Yes! We ship to over 15 countries worldwide.</p>" } },
        { "type": "faq", "settings": { "question": "Are your cacao products certified organic?", "answer": "<p>All our cacao is sourced from certified organic farms.</p>" } },
        { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "<p>We offer a 30-day satisfaction guarantee on all cacao products.</p>" } },
        { "type": "faq", "settings": { "question": "Can I buy cacao in bulk for my business?", "answer": "<p>Yes — we offer wholesale pricing. Reach out for a custom quote.</p>" } },
        { "type": "faq", "settings": { "question": "How should I store cacao products?", "answer": "<p>Store in a cool, dry place away from sunlight.</p>" } }
      ]
    }
  ]
}
{% endschema %}
