{% comment %}
  Homepage "Complete Cacao Collection" — theme-managed catalog.

  Renders the same tiles as the shop page from snippets/ts-product-info.liquid,
  so the homepage and /collections/all can never drift. Product list comes from
  snippets/ts-product-handles.liquid.
{% endcomment %}

{%- capture handles_csv -%}{%- render 'ts-product-handles' -%}{%- endcapture -%}
{%- assign handles = handles_csv | strip | split: ',' -%}

<section id="all-products" class="ts-vbc-all-products">
  <div class="ts-vbc-all-products__glow" aria-hidden="true"></div>
  <div class="ts-page-width">
    <div class="ts-vbc-all-products__head">
      <p class="ts-products__kicker">{{ section.settings.kicker }}</p>
      <h2 class="ts-products__title">
        {{ section.settings.title_line_1 }} <em>{{ section.settings.title_line_2 }}</em>
      </h2>
      {% if section.settings.subtitle != blank %}
        <p class="ts-vbc-all-products__sub">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ts-catalog__grid">
      {% for handle in handles %}
        {% render 'ts-product-info', handle: handle, mode: 'card' %}
      {% endfor %}
    </div>

    {% if section.settings.show_view_all %}
      <div class="ts-products__footer">
        <a class="ts-btn-outline" href="{{ routes.all_products_collection_url }}">
          {{ section.settings.view_all_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product grid (full range)",
  "tag": "section",
  "class": "section-ts-vbc-all-products",
  "settings": [
    {
      "type": "paragraph",
      "content": "Products come from snippets/ts-product-handles.liquid and ts-product-info.liquid — the same source as the shop page."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Full Range"
    },
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title line 1",
      "default": "Complete Cacao"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title line 2 (accent)",
      "default": "Collection"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "From raw whole beans to refined cacao butter — every form of pure cacao you need, all in one place."
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"view all\" button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "View All Products"
    }
  ],
  "presets": [{ "name": "Product grid (full range)" }]
}
{% endschema %}
